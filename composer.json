{
  "name": "prikogstreg/online-invitations",
  "description": "WooCommerce online invitation projects for Prik & Streg",
  "type": "wordpress-plugin",
  "license": "proprietary",
  "require": {
    "php": ">=8.1"
  },
  "autoload": {
    "psr-4": {
      "PrikOgStreg\\OnlineInvitations\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "PrikOgStreg\\OnlineInvitations\\Tests\\": "tests/"
    }
  },
  "require-dev": {
    "brain/monkey": "^2.6",
    "phpunit/phpunit": "^10.5"
  },
  "scripts": {
    "test": "phpunit",
    "test:unit": "phpunit --testsuite unit",
    "test:integration": "phpunit --testsuite integration",
    "test:e2e": "phpunit --testsuite e2e",
    "i18n": "bash scripts/i18n.sh"
  },
  "config": {
    "sort-packages": true
  }
}
